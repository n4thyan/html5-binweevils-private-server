node_modules/
vendor/
.env
.env.*
!.env.example

# Runtime/generated data
data/*.json
!data/.gitkeep
logs/
*.log

# OS/editor noise
.DS_Store
Thumbs.db
.vscode/
.idea/

# Build/output folders
dist/
build/
.cache/

# Raw FFDec room exports are kept local only because filenames can be too long for Git
/reference/rooms/

